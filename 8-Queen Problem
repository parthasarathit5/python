N = 8

def solve(board, row):
    if row == N:
        for r in board:
            print(r)
        print()
        return True

    for col in range(N):
        safe = True

        for i in range(row):
            if board[i] == col or abs(board[i]-col)==abs(i-row):
                safe = False

        if safe:
            board[row] = col
            if solve(board, row+1):
                return True

    return False

board = [-1]*N
solve(board, 0)



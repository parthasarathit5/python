MAX = 1000
MIN = -1000

def alphabeta(depth, alpha, beta, maximizing):

    if depth == 3:
        return depth

    if maximizing:
        best = MIN

        for i in range(2):
            val = alphabeta(depth+1,alpha,beta,False)
            best = max(best,val)
            alpha = max(alpha,best)

            if beta <= alpha:
                break

        return best

print(alphabeta(0,MIN,MAX,True))
#output
3

from itertools import permutations

graph = {
    'A':{'B':10,'C':15,'D':20},
    'B':{'A':10,'C':35,'D':25},
    'C':{'A':15,'B':35,'D':30},
    'D':{'A':20,'B':25,'C':30}
}

cities = list(graph.keys())

min_cost = float('inf')

for path in permutations(cities[1:]):
    cost = 0
    route = ['A'] + list(path) + ['A']

    for i in range(len(route)-1):
        cost += graph[route[i]][route[i+1]]

    min_cost = min(min_cost,cost)

print(min_cost)
